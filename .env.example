# ============================================================================
# Dump Sniper — 精简版配置 (clean baseline)
# ============================================================================
# 复制为 .env，填入最下方【密钥区】即可；策略字段已按目标规则设好。
# ⚠️ 首次部署保持 DRY_RUN=true，确认有信号、买卖正常后再切 LIVE。
# ============================================================================

# ============ 运行模式 ============
DRY_RUN=true
POSITION_SIZE_SOL=1

# ============ 成交事件质量保护 ============
# 拒绝零成交事件；CPI/余额回退价格必须锚定到可信池子价格，防止 1、100x 等错误价格污染策略和特征库。
SWAP_SANITIZER_ENABLED=true
SWAP_SANITIZER_MAX_JUMP_RATIO=2
SWAP_SANITIZER_MARKET_MAX_RATIO=5
SWAP_SANITIZER_MARKET_MAX_AGE_MS=300000
SWAP_SANITIZER_CONFIRM_WINDOW_MS=5000
SWAP_SANITIZER_CONFIRM_MIN_SAMPLES=3
SWAP_SANITIZER_CONFIRM_MIN_SPAN_MS=100
SWAP_SANITIZER_CONFIRM_CLUSTER_RATIO=1.25
SWAP_SANITIZER_DEBUG=false

# ============ Buy: Strategy V5 activity burst ============
# Arm on broad 1-minute activity, then require a confirmed 5-second net-flow turn.
# Pool SOL, liquidity and FDV eligibility are handled by the token watchlist.
ACTIVITY_FLOW_ENABLED=true
ACTIVITY_FLOW_REPLACE_DUMP_SIGNAL=true
ACTIVITY_FLOW_ENTRY_MODE=ACTIVITY_BURST_V5
ACTIVITY_FLOW_1M_MIN_VOLUME_USD=3000
ACTIVITY_FLOW_1M_MIN_VOLUME_SOL=
ACTIVITY_FLOW_1M_MIN_TRADES=25
ACTIVITY_FLOW_COOLDOWN_MS=0
ACTIVITY_FLOW_ARM_WINDOW_MS=30000
ACTIVITY_FLOW_ARM_CANCEL_MIN_VOLUME_1M_SOL=
ACTIVITY_FLOW_ARM_MIN_UNIQUE_TRADERS_1M=8
ACTIVITY_FLOW_ARM_MAX_LARGEST_BUY_SHARE_1M=0.25
ACTIVITY_FLOW_ARM_CANCEL_MAX_LARGEST_BUY_SHARE_1M=0.40
ACTIVITY_FLOW_ARM_MIN_VOLATILITY_1M_PCT=1.1
ACTIVITY_FLOW_TRIGGER_MIN_VOLUME_5S_SOL=2
ACTIVITY_FLOW_TRIGGER_MIN_TRADES_5S=4
ACTIVITY_FLOW_TRIGGER_MIN_UNIQUE_BUYERS_5S=2
ACTIVITY_FLOW_TRIGGER_MIN_TX_ACCEL_5S=2
ACTIVITY_FLOW_TRIGGER_MIN_RANGE_5S_PCT=1
ACTIVITY_FLOW_TRIGGER_MIN_PRICE_CHANGE_10S_PCT=0
ACTIVITY_FLOW_TRIGGER_MAX_PRICE_CHANGE_10S_PCT=6
ACTIVITY_FLOW_TRIGGER_CONFIRM_MIN_GAP_MS=1000
ACTIVITY_FLOW_TRIGGER_CONFIRM_MAX_GAP_MS=3000
ACTIVITY_FLOW_WINDOW_60S_MS=60000
ACTIVITY_FLOW_MAX_SIGNAL_AGE_MS=5000
ACTIVITY_FLOW_DEBUG=false

# ============ 旧砸单阈值：仅供 fallback/安全护栏使用，不再作为默认买入入口 ============
MIN_SELL_SOL=20
MIN_PRICE_IMPACT_PCT=10
MIN_TRIGGER_SELL_COUNT=2
NEW_COIN_MIN_IMPACT_PCT=10
MAX_PRICE_IMPACT_PCT=30        # 安全护栏：跌幅 >30% 视为已 rug，不接
MIN_POOL_QUOTE_SOL=30          # 安全护栏：池子 SOL <30 不买

# ============ Sell ============
# Exit when two closed 15-second net-flow values turn positive to negative and seller breadth confirms.
# Also exit no-bounce positions at 90s, enforce a 180s timeout, and retain TP/trailing/SL protection.
FLOW_REVERSAL_EXIT_ENABLED=true
FLOW_REVERSAL_EXIT_MODE=FLOW_TURN_15S
FLOW_REVERSAL_EXIT_REQUIRE_SELLER_BREADTH=true
TRAILING_ACTIVATE_PCT=20
TRAILING_DRAWDOWN_PCT=10
TRAILING_MIN_HWM_AGE_MS=2000
TAKE_PROFIT_PCT=100
RSI_1M_EXIT_ENABLED=false
RSI_1M_EXIT_THRESHOLD=80
FIXED_STOP_LOSS_PCT=-20
EMERGENCY_STOP_LOSS_PCT=0
NO_BOUNCE_EXIT_ENABLED=true
NO_BOUNCE_EXIT_MS=90000
NO_BOUNCE_MAX_PEAK_PNL_PCT=5
NO_BOUNCE_FLOW_WINDOW_MS=30000
MAX_HOLD_MS=180000
STABILIZATION_MS=5000
STABILIZATION_EMERGENCY_DRAWDOWN_PCT=0

# 同币最多加仓 1 次：价格相对第一笔入场价下跌 20% 后，下一次合格买入信号可加仓。
# 任一仓位触发任何自动退出条件时，同币全部仓位按队列逐笔卖出。
ADDON_ENABLED=0
ADDON_DROP_PCT=20

# ============ 监控列表过滤（TokenWatchdog，每 1min 巡检）============
#   FDV $1.5万~$100万 或 LP <$3000 移除 / 24h量 <$5000 移除；AGE 仅记录，不参与移除
MIN_FDV_USD=15000
MAX_FDV_USD=1000000
MIN_LIQUIDITY_USD=3000
MIN_VOLUME_24H_USD=5000
MAX_MINT_AGE_HOURS=0
NEW_COIN_AGE_THRESHOLD_MS=0
# Values above 60000 are clamped so FDV/LP and AGE resolution still run every minute.
WATCHDOG_CHECK_INTERVAL_MS=60000
WATCHDOG_MARKET_STALE_MS=180000
WATCHDOG_MARKET_BATCH_SIZE=30
WATCHDOG_MARKET_BATCH_DELAY_MS=250
WATCHDOG_MARKET_FALLBACK_MAX_PER_CYCLE=10
MAX_WATCHED_TOKENS=500

# ============ Pump.fun graduation discovery ============
# WebSocket detects migrate immediately; migration-wallet polling fills gaps.
# Admission checks FDV and LP only. AGE starts from the confirmed migration time.
PUMP_DISCOVERY_ENABLED=true
PUMP_DISCOVERY_WS_URL=
PUMP_DISCOVERY_POLL_INTERVAL_MS=5000
PUMP_DISCOVERY_POLL_LIMIT=100
PUMP_DISCOVERY_STARTUP_LOOKBACK_SEC=120
PUMP_DISCOVERY_MARKET_INITIAL_DELAY_MS=2000
PUMP_DISCOVERY_MARKET_RETRIES=8
PUMP_DISCOVERY_MARKET_RETRY_MS=3000
PUMP_DISCOVERY_MAX_CONCURRENT_CHECKS=3

# ============================================================================
# ⚠️ 关键「关闭开关」——代码默认会启用这些旧机制，删除/留空会改变行为，勿删！
# ============================================================================
LOW_PEAK_TIMEOUT_MS=0
OLD_COIN_TIMEOUT_MS=0
VOL_LOW_TIMEOUT_MS=0
VOL_MID_TIMEOUT_MS=0
VOL_HIGH_TIMEOUT_MS=0
DEFENSE_ACTIVATE_MS=0
DEFENSE_STOP_LOSS_PCT=0
DEFENSE_TRAILING_DRAWDOWN_PCT=0
DEFENSE_PROFIT_ACTIVATE_PCT=0
NO_BUY_REMOVE_MS=0              # 代码默认 24h 未买入即移除 → 关
OLD_COIN_MIN_POOL_SOL=0         # 代码默认 100 → 关
MAX_DUMP_DEPTH_PCT=0           # 代码默认 50（砸盘 >50% 拒绝）→ 关
MAX_PRE_VOL_5M_PCT=0          # 代码默认 15（砸前 5min 量过滤）→ 关
MAX_WATCH_DURATION_MS=0
# ⚠️ 下面两个：留空会回退到上面的 MAX/MIN_FDV_USD，导致信号期 FDV 误拒（你遇到的"没信号"诱因之一），必须显式 0
SIGNAL_MAX_FDV_USD=0
SIGNAL_MIN_FDV_USD=0

# ============ 实验性出场/过滤：冗余保险（代码默认已关，显式 0 防被改回开启）============
RANGE_STOP_ENABLED=0
TREND_STOP_ENABLED=0
TIMED_TP_ENABLED=0
EARLY_LOW_PEAK_CUT_ENABLED=0
TREND_FILTER_ENABLED=0
RSI_FILTER=off
RSI_30S_MIN=0

# ============ 信号去重 / 新鲜度 / 风控 ============
MAX_SIGNAL_SLOT_GAP=200       # 砸单 slot 落后 >200(~80s) 丢弃（防迟到接刀）。勿设 0
MAX_PUSH_LAG_MS=5000
SELLER_TX_DEDUP_MS=600000
SELLER_MINT_DEDUP_MS=30000
COOLDOWN_MS_PER_TOKEN=0
REBUY_COOLDOWN_MS=300000
MAX_CONCURRENT_POSITIONS=60
PRICE_MAX_JUMP_RATIO=1.5
PRICE_CONFIRM_WINDOW_MS=3000
PRICE_CONFIRM_MIN_SAMPLES=2
POSITION_MAX_JUMP_RATIO=5
POSITION_EXTREME_RATIO=50

# ============ Pool 状态缓存（零延迟买入路径，勿改）============
POOL_POLL_INTERVAL_MS=500
POOL_STATE_POSITION_REFRESH_MS=500
POOL_STATE_SIGNAL_REFRESH_MS=2000
POOL_STATE_TICK_MS=200
AUTO_FILL_POOLS_ON_START=true

# ============ 滑点 / 优先费 / Jito ============
BUY_SLIPPAGE_BPS=500
BUY_MAX_ESTIMATED_SLIPPAGE_PCT=5
SELL_SLIPPAGE_BPS=500
PRIORITY_FEE_DYNAMIC=false
BUY_PRIORITY_LEVEL=veryHigh
SELL_PRIORITY_LEVEL=medium
BUY_MIN_PRIORITY_FEE_LAMPORTS=500000
SELL_MIN_PRIORITY_FEE_LAMPORTS=500000
BUY_CAP_PRIORITY_FEE_LAMPORTS=500000
SELL_CAP_PRIORITY_FEE_LAMPORTS=500000
BUY_MAX_PRIORITY_FEE_LAMPORTS=500000
SELL_MAX_PRIORITY_FEE_LAMPORTS=500000
MAX_PRIORITY_FEE_LAMPORTS=500000
PRIORITY_FEE_REFRESH_MS=500
JITO_TIP_LAMPORTS=200000
COMPUTE_UNIT_LIMIT=185000

# ============ 杂项 / 稳定性 ============
SOL_PRICE_USD=72
MAX_REPLAY_SLOTS=5            # LaserStream 重连最多回放 5 slot（防 RSS 死亡螺旋）。勿改
MAX_UPTIME_MS=10800000        # 空仓时每 3h 自动重启释放 native 内存
COMPETITOR_ENRICH=false
COMPETITOR_FOLLOW_SELL=false
SWAP_EVENT_LOG_ENABLED=true
SWAP_SANITIZER_MIN_POOL_QUOTE_SOL=30
SWAP_SANITIZER_CONFIRM_MIN_INDEPENDENT_SOURCES=2

# ============ Strategy Lab feature database ============
# Records per-second feature snapshots for recently active tokens, 15s/1m candles,
# first-time events, bot latency, and delayed future-return labels.
STRATEGY_LAB_ENABLED=true
STRATEGY_LAB_SNAPSHOT_INTERVAL_MS=1000
STRATEGY_LAB_RETENTION_MS=300000
STRATEGY_LAB_LABEL_ENABLED=true
STRATEGY_LAB_LABEL_INTERVAL_MS=10000
STRATEGY_LAB_LABEL_BATCH_SIZE=1000
STRATEGY_LAB_LABEL_MAX_BATCHES_PER_TICK=4
STRATEGY_LAB_LABEL_WARN_AGE_MS=300000
# false = snapshot recently active tokens only; true = snapshot the whole watchlist every interval.
STRATEGY_LAB_SNAPSHOT_ALL_ACTIVE=false
STRATEGY_LAB_BUY_BURST_THRESHOLD=10
STRATEGY_LAB_TPS_DOUBLE_MIN=5
STRATEGY_LAB_LP_CHANGE_PCT=10
STRATEGY_LAB_FDV_BANDS_USD=50000,100000,250000,500000,1000000
STRATEGY_LAB_SMART_WALLETS=

# ============================================================================
# 【密钥区】—— 必填，从旧服务器 .env 复制 ——
# ============================================================================
HELIUS_API_KEY=
HELIUS_RPC_URL=
HELIUS_STAKED_RPC_URL=
HELIUS_SENDER_ENDPOINT=https://sender.helius-rpc.com/fast
HELIUS_SENDER_ENDPOINTS=http://fra-sender.helius-rpc.com/fast,http://ewr-sender.helius-rpc.com/fast,http://tyo-sender.helius-rpc.com/fast
HELIUS_LASERSTREAM_ENDPOINT=https://laserstream-mainnet-fra.helius-rpc.com
HELIUS_LASERSTREAM_ENDPOINTS=https://laserstream-mainnet-fra.helius-rpc.com,https://laserstream-mainnet-ewr.helius-rpc.com,https://laserstream-mainnet-tyo.helius-rpc.com
HELIUS_LASERSTREAM_TOKEN=
BIRDEYE_API_KEY=
WALLET_PRIVATE_KEY_BS58=

# ============ Dashboard ============
DASHBOARD_PORT=3001
BIND_HOST=0.0.0.0
WEBHOOK_SECRET=
DASHBOARD_TOKEN=
